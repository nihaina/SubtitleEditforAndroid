<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
        app:title="设置" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 默认编码设置 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="默认编码"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinnerEncoding"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp" />

            <!-- AI 翻译设置 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI 翻译设置（硅基流动平台）"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="API Key"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="模型名称"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etModel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="deepseek-ai/DeepSeek-V3.2-Exp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="源语言（留空自动检测）"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSourceLanguage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="自动检测" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="目标语言"
                android:layout_marginBottom="24dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTargetLanguage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="中文" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 播放行为 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="播放行为"
                android:textStyle="bold"
                android:paddingTop="16dp"
                android:paddingBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="选中字幕时在区间内循环播放"
                        android:textSize="14sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="选中字幕块后，播放头到达字幕结束时间时自动跳回开始时间循环"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_variant"
                        android:paddingTop="2dp"/>
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchLoopSelectedSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- 波形缓存存放位置 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="波形图和频谱图缓存存放位置"
                android:textStyle="bold"
                android:paddingTop="16dp"
                android:paddingBottom="4dp"/>

            <RadioGroup
                android:id="@+id/rgWaveformCache"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbCacheApp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="存放到软件缓存目录（默认，可一键清除）"/>

                <RadioButton
                    android:id="@+id/rbCacheSource"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="存放到音频文件同目录"/>
            </RadioGroup>

            <!-- 波形图缓存统计和操作 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tvWaveformCacheSize"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/secondary"
                    android:textSize="12sp"
                    android:visibility="gone"/>

                <Button
                    android:id="@+id/btnClearWaveformCache"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="清除波形缓存"
                    android:enabled="false"
                    android:textSize="12sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"/>
            </LinearLayout>

            <!-- 频谱图缓存统计和操作 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvSpectrogramCacheSize"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/secondary"
                    android:textSize="12sp"
                    android:visibility="gone"/>

                <Button
                    android:id="@+id/btnClearSpectrogramCache"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="清除频谱缓存"
                    android:enabled="false"
                    android:textSize="12sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnSaveSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="保存设置" />

            <!-- GitHub 项目地址 -->
            <TextView
                android:id="@+id/tvGithub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="项目地址: https://github.com/nihaina/SubtitleEditforAndroid"
                android:textSize="16sp"
                android:textColor="@color/design_default_color_primary"
                android:padding="16dp"
                android:layout_marginTop="16dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
