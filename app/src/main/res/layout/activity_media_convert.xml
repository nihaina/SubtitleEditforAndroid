<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:title="格式转换"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- 选择文件卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="源文件"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:paddingBottom="6dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPickFile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="选择音视频文件"/>

                    <TextView
                        android:id="@+id/tvNoSource"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="未选择文件"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:paddingTop="6dp"/>

                    <TextView
                        android:id="@+id/tvSourceFile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:paddingTop="6dp"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tvSourceInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#9E9E9E"
                        android:fontFamily="monospace"
                        android:paddingTop="4dp"
                        android:visibility="gone"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 输出目录卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="输出目录"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:paddingBottom="6dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSelectOutputDir"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="选择输出目录"/>

                    <TextView
                        android:id="@+id/tvOutputDir"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="默认：Download/SubtitleEdit/Convert"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp"
                        android:paddingTop="4dp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 输出格式卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/groupFormatSelect"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="输出格式"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:paddingBottom="6dp"/>

                    <!-- 视频格式 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="视频格式"
                        android:textSize="12sp"
                        android:textColor="#9E9E9E"
                        android:paddingBottom="4dp"/>

                    <RadioGroup
                        android:id="@+id/rgVideoFormats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#2A2A2A"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"/>

                    <!-- 音频格式 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="音频格式（视频转音频 / 纯音频）"
                        android:textSize="12sp"
                        android:textColor="#9E9E9E"
                        android:paddingBottom="4dp"/>

                    <RadioGroup
                        android:id="@+id/rgAudioFormats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 高级选项卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <Button
                        android:id="@+id/btnToggleAdvanced"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="▶ 高级选项"
                        android:textSize="13sp"
                        android:gravity="start|center_vertical"/>

                    <LinearLayout
                        android:id="@+id/layoutAdvanced"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <!-- 视频编码器 -->
                        <LinearLayout
                            android:id="@+id/layoutVideoCodec"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="6dp">
                            <TextView
                                android:layout_width="100dp"
                                android:layout_height="wrap_content"
                                android:text="视频编码器"
                                android:textSize="13sp"/>
                            <Spinner
                                android:id="@+id/spinnerVideoCodec"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"/>
                        </LinearLayout>

                        <!-- 分辨率 -->
                        <LinearLayout
                            android:id="@+id/layoutResolution"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="6dp">
                            <TextView
                                android:layout_width="100dp"
                                android:layout_height="wrap_content"
                                android:text="分辨率"
                                android:textSize="13sp"/>
                            <Spinner
                                android:id="@+id/spinnerResolution"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"/>
                        </LinearLayout>

                        <!-- 视频码率 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="6dp">
                            <TextView
                                android:layout_width="100dp"
                                android:layout_height="wrap_content"
                                android:text="视频码率"
                                android:textSize="13sp"/>
                            <EditText
                                android:id="@+id/etVideoBitrate"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="空=自动 (单位: kbps)"
                                android:inputType="number"
                                android:importantForAutofill="no"/>
                        </LinearLayout>

                        <!-- CRF 质量 -->
                        <LinearLayout
                            android:id="@+id/layoutCrf"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="6dp">
                            <TextView
                                android:layout_width="100dp"
                                android:layout_height="wrap_content"
                                android:text="视频质量"
                                android:textSize="13sp"/>
                            <Spinner
                                android:id="@+id/spinnerCrf"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"/>
                        </LinearLayout>

                        <EditText
                            android:id="@+id/etCustomCrf"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="自定义 CRF 值 (0-51，越小越好)"
                            android:inputType="number"
                            android:layout_marginStart="100dp"
                            android:visibility="gone"
                            android:importantForAutofill="no"/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#2A2A2A"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="2dp"/>

                        <!-- 音频编码器 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="6dp">
                            <TextView
                                android:layout_width="100dp"
                                android:layout_height="wrap_content"
                                android:text="音频编码器"
                                android:textSize="13sp"/>
                            <Spinner
                                android:id="@+id/spinnerAudioCodec"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"/>
                        </LinearLayout>

                        <!-- 音频码率 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="6dp">
                            <TextView
                                android:layout_width="100dp"
                                android:layout_height="wrap_content"
                                android:text="音频码率"
                                android:textSize="13sp"/>
                            <EditText
                                android:id="@+id/etAudioBitrate"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="空=自动 (单位: kbps)"
                                android:inputType="number"
                                android:importantForAutofill="no"/>
                        </LinearLayout>

                        <!-- 采样率 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="6dp">
                            <TextView
                                android:layout_width="100dp"
                                android:layout_height="wrap_content"
                                android:text="采样率"
                                android:textSize="13sp"/>
                            <Spinner
                                android:id="@+id/spinnerSampleRate"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"/>
                        </LinearLayout>

                        <!-- 声道 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="6dp"
                            android:layout_marginBottom="4dp">
                            <TextView
                                android:layout_width="100dp"
                                android:layout_height="wrap_content"
                                android:text="声道"
                                android:textSize="13sp"/>
                            <Spinner
                                android:id="@+id/spinnerChannels"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"/>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 进度和日志卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <ProgressBar
                        android:id="@+id/progressBar"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="0"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnConvert"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="开始转换"
                            android:enabled="false"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCancel"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="取消"
                            android:layout_marginStart="8dp"
                            android:visibility="gone"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnShareOutput"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="分享结果"
                            android:layout_marginStart="8dp"
                            android:visibility="gone"/>

                    </LinearLayout>

                    <!-- 日志输出 -->
                    <ScrollView
                        android:id="@+id/scrollLog"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginTop="8dp"
                        android:background="#1A1A1A"
                        android:padding="4dp">

                        <TextView
                            android:id="@+id/tvLog"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="#CCCCCC"
                            android:fontFamily="monospace"
                            android:padding="4dp"/>

                    </ScrollView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
