<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".EditorActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:title="@string/app_name" />

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- 搜索条 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/searchBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- 第一行：搜索输入 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- 搜索输入框 -->
                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/search_hint"
                        android:inputType="text"
                        android:maxLines="1"
                        android:background="@null"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:importantForAutofill="no" />

                    <!-- 上一项按钮 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSearchPrevious"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/search_previous"
                        android:textSize="12sp"
                        android:layout_marginEnd="4dp" />

                    <!-- 下一项按钮 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSearchNext"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/search_next"
                        android:textSize="12sp"
                        android:layout_marginEnd="4dp" />

                    <!-- 关闭按钮 -->
                    <ImageButton
                        android:id="@+id/btnSearchClose"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_close"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/search_close" />

                </LinearLayout>

                <!-- 第二行：替换输入和操作按钮 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <!-- 替换输入框 -->
                    <EditText
                        android:id="@+id/etReplace"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="替换为"
                        android:inputType="text"
                        android:maxLines="1"
                        android:background="@null"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:importantForAutofill="no" />

                    <!-- 替换按钮 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnReplace"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="替换"
                        android:textSize="12sp"
                        android:layout_marginEnd="4dp" />

                    <!-- 全部替换按钮 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnReplaceAll"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="全部替换"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 音频播放器容器（仅在打开音频文件时显示） -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/audioPlayerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- 音频文件信息 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_file"
                        android:contentDescription="音频文件"
                        app:tint="@color/primary" />

                    <TextView
                        android:id="@+id/tvAudioFileName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp"
                        android:maxLines="1"
                        android:ellipsize="middle"
                        tools:text="audio.mp3" />

                </LinearLayout>

                <!-- 波形区域容器 -->
                <LinearLayout
                    android:id="@+id/waveformSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp">

                    <!-- 工具栏：展开/折叠 + 振幅缩放 + 模式切换 -->
                    <LinearLayout
                        android:id="@+id/waveformToolbar"
                        android:layout_width="match_parent"
                        android:layout_height="32dp"
                        android:orientation="horizontal"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:gravity="center_vertical"
                        android:background="@color/waveform_toolbar_bg">

                        <!-- 展开/折叠按钮 -->
                        <TextView
                            android:id="@+id/btnToggleWaveform"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:text="▼"
                            android:gravity="center"
                            android:textSize="11sp"
                            android:textColor="#CCCCCC"
                            android:background="@drawable/bg_waveform_btn"
                            android:clickable="true"
                            android:focusable="true"
                            android:contentDescription="展开/折叠波形图"/>

                        <!-- 标签 -->
                        <TextView
                            android:id="@+id/tvWaveformLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="波形图"
                            android:textSize="11sp"
                            android:paddingStart="6dp"
                            android:textColor="#9E9E9E"/>

                        <!-- 模式切换：波形 ↔ 频谱 -->
                        <TextView
                            android:id="@+id/btnToggleDisplayMode"
                            android:layout_width="wrap_content"
                            android:layout_height="24dp"
                            android:text="频谱"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:gravity="center"
                            android:textSize="11sp"
                            android:textColor="#CCCCCC"
                            android:background="@drawable/bg_waveform_btn"
                            android:clickable="true"
                            android:focusable="true"
                            android:layout_marginEnd="4dp"
                            android:contentDescription="切换波形/频谱"/>

                        <!-- 振幅缩小 -->
                        <TextView
                            android:id="@+id/btnAmplitudeZoomOut"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:text="−"
                            android:gravity="center"
                            android:textSize="15sp"
                            android:textColor="#CCCCCC"
                            android:background="@drawable/bg_waveform_btn"
                            android:clickable="true"
                            android:focusable="true"
                            android:layout_marginEnd="4dp"
                            android:contentDescription="缩小振幅"/>

                        <!-- 振幅放大（长按重置） -->
                        <TextView
                            android:id="@+id/btnAmplitudeZoomIn"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:text="+"
                            android:gravity="center"
                            android:textSize="15sp"
                            android:textColor="#CCCCCC"
                            android:background="@drawable/bg_waveform_btn"
                            android:clickable="true"
                            android:focusable="true"
                            android:contentDescription="放大振幅（长按重置）"/>

                    </LinearLayout>

                    <!-- 波形图本体（折叠时 GONE） -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/timelineContainer"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        app:cardCornerRadius="4dp"
                        app:cardElevation="1dp">

                        <com.subtitleedit.view.WaveformTimelineView
                            android:id="@+id/waveformTimelineView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_waveform_placeholder" />

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- 播放控制 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp">

                    <!-- 播放/暂停按钮 -->
                    <ImageButton
                        android:id="@+id/btnPlayPause"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_media_play"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="播放/暂停"
                        app:tint="@color/primary" />

                    <!-- 当前时间 -->
                    <TextView
                        android:id="@+id/tvCurrentTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_surface"
                        android:textSize="12sp"
                        tools:text="00:00:00" />

                    <!-- 进度条 -->
                    <SeekBar
                        android:id="@+id/seekBar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp" />

                    <!-- 总时长 -->
                    <TextView
                        android:id="@+id/tvTotalTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_surface"
                        android:textSize="12sp"
                        tools:text="05:30:00" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 顶部工具栏 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- 文件信息和格式 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvFileName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp"
                        android:maxLines="1"
                        android:ellipsize="middle"
                        tools:text="example.srt" />

                </LinearLayout>

                <!-- 格式信息 -->
                <TextView
                    android:id="@+id/tvFormatInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/on_surface"
                    android:textSize="12sp"
                    tools:text="格式：SRT | 条目数：50" />
                
                <!-- 选中提示 -->
                <TextView
                    android:id="@+id/tvSelectedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:visibility="gone"
                    tools:text="已选择 3 项" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 字幕列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSubtitles"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="8dp"
            tools:listitem="@layout/item_subtitle" />

        <!-- 源视图编辑器（用于 TXT 文件或手动切换） -->
        <ScrollView
            android:id="@+id/svSourceView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="vertical"
            android:fadeScrollbars="false"
            android:scrollbarSize="6dp"
            android:scrollbarThumbVertical="@android:color/darker_gray"
            android:overScrollMode="always"
            android:visibility="gone">

            <EditText
                android:id="@+id/etSourceView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top|start"
                android:padding="12dp"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:inputType="textMultiLine|textNoSuggestions"
                android:scrollbars="none"
                android:importantForAutofill="no"
                android:background="@null"
                android:isScrollContainer="false"
                tools:text="Line 1\nLine 2\nLine 3" />

        </ScrollView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
