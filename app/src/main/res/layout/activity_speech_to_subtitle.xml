<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".SpeechToSubtitleActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:title="语音转字幕" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <!-- 文件选择区域 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="选择音频/视频文件"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="支持 MP3, WAV, FLAC, MP4, MKV 等格式"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface_variant" />

                <Button
                    android:id="@+id/btnSelectFile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="选择文件"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

                <TextView
                    android:id="@+id/tvSelectedFile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="未选择文件"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface_variant"
                    android:ellipsize="middle"
                    android:singleLine="true" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 模型选择 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="识别模型"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface" />

                <!-- Encoder 文件 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Encoder 模型"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface" />

                <TextView
                    android:id="@+id/tvEncoderFile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="未选择"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_variant"
                    android:ellipsize="middle"
                    android:singleLine="true" />

                <Button
                    android:id="@+id/btnSelectEncoder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="选择 Encoder"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

                <!-- Decoder 文件 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Decoder 模型"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface" />

                <TextView
                    android:id="@+id/tvDecoderFile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="未选择"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_variant"
                    android:ellipsize="middle"
                    android:singleLine="true" />

                <Button
                    android:id="@+id/btnSelectDecoder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="选择 Decoder"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

                <!-- Tokens 文件 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Tokens 文件"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface" />

                <TextView
                    android:id="@+id/tvTokensFile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="未选择"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_variant"
                    android:ellipsize="middle"
                    android:singleLine="true" />

                <Button
                    android:id="@+id/btnSelectTokens"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="选择 Tokens"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

                <!-- VAD 模型文件 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="VAD 模型（可选）"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface" />

                <TextView
                    android:id="@+id/tvVadFile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="未选择"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_variant"
                    android:ellipsize="middle"
                    android:singleLine="true" />

                <Button
                    android:id="@+id/btnSelectVad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="选择 VAD 模型"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="需要选择 3 个文件：encoder.onnx、decoder.onnx、tokens.txt"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_variant" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="VAD 模型用于精确检测语音段，提高字幕时间轴准确性（推荐使用 silero_vad.onnx）"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_variant" />

                <TextView
                    android:id="@+id/tvModelGuide"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="点击查看模型下载指引"
                    android:textSize="12sp"
                    android:textColor="@color/primary"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 语言选择 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="源语言"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface" />

                <Spinner
                    android:id="@+id/spinnerSourceLanguage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:minHeight="48dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 输出格式选择 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="输出格式"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface" />

                <Spinner
                    android:id="@+id/spinnerOutputFormat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:minHeight="48dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 高级选项 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="保存波形图"
                        android:textSize="16sp"
                        android:textColor="@color/on_surface" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchSaveWaveform"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="生成字幕的同时保存波形图文件"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface_variant" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 开始按钮 -->
        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:text="开始转换"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- 进度显示（初始隐藏） -->
        <LinearLayout
            android:id="@+id/layoutProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="正在处理..."
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressIndicator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="0" />

            <TextView
                android:id="@+id/tvProgressStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="正在分析音频..."
                android:textSize="14sp"
                android:textColor="@color/on_surface_variant" />

            <!-- 实时识别结果显示 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="识别内容："
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="8dp"
                android:background="@android:color/transparent"
                android:padding="8dp">

                <TextView
                    android:id="@+id/tvRealtimeResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="等待识别..."
                    android:textSize="14sp"
                    android:textColor="@color/on_surface"
                    android:lineSpacingExtra="4dp" />

            </ScrollView>

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="取消"
                style="@style/Widget.Material3.Button.TextButton" />

        </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
